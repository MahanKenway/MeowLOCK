# =========================================================
# Environment Variables & API Keys Configuration
# =========================================================
# This file serves as a template for environment variables.
# Actual secret values are managed securely via AI Studio Settings
# or stored in a local .env file (which is excluded from git via .gitignore).

# 1. GEMINI_API_KEY
# Description: Required for Google Gemini AI features and study assistance.
# Source: Automatically injected by AI Studio runtime or set via AI Studio Secrets.
GEMINI_API_KEY=""

# 2. SPOTIFY_CLIENT_ID
# Description: Client ID for Spotify OAuth integration.
SPOTIFY_CLIENT_ID=""

# 3. SPOTIFY_CLIENT_SECRET
# Description: Client Secret for Spotify OAuth authentication (Server-side only).
SPOTIFY_CLIENT_SECRET=""

# 4. NASA_API_KEY
# Description: API Key for NASA Astronomy Picture of the Day (APOD) & space imagery.
NASA_API_KEY=""

# 5. ABSTRACT_API_HOLIDAYS_KEY
# Description: API Key for Abstract API global holidays & calendar data.
ABSTRACT_API_HOLIDAYS_KEY=""

# 6. YOUTUBE_API_KEY
# Description: Optional API Key for YouTube search and music integrations.
YOUTUBE_API_KEY=""

# 7. APP_URL
# Description: The base deployment URL for self-referential links and OAuth callbacks.
APP_URL="http://localhost:3000"
